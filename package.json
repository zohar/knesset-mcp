{
  "name": "knesset-mcp",
  "version": "1.1.1",
  "description": "MCP server for the Israeli Knesset parliamentary information API",
  "type": "module",
  "main": "build/knesset-mcp-server.js",
  "bin": {
    "knesset-mcp": "build/knesset-mcp-server.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/knesset-mcp-server.js",
    "dev": "ts-node-esm knesset-mcp-server.ts",
